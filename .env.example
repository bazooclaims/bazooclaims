# Header logo: public/logo-bazoo.png (replace the file to update branding sitewide in the nav).

# Public site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_COMPANY_PHONE=+441234567890

# WhatsApp — click-to-chat (wa.me). Set ONE of these in .env.local (create from this file):
#
# Preferred: international number, digits only (no + or spaces), e.g. UK mobile:
#   NEXT_PUBLIC_WHATSAPP_E164=447700900123
#
# Or paste a full number — spaces and + are stripped automatically:
#   NEXT_PUBLIC_WHATSAPP_NUMBER=+44 7700 900123
#
# Or:
#   NEXT_PUBLIC_WHATSAPP=07700900123
# (UK numbers starting with 0 are converted to 44… for WhatsApp.)
#
NEXT_PUBLIC_WHATSAPP_E164=
# NEXT_PUBLIC_WHATSAPP_NUMBER=+44 7700 900123
# NEXT_PUBLIC_WHATSAPP=07700900123
#
# If all are empty, the bottom-right FAB still appears and links to /start-your-claim.

# Admin dashboard — http://localhost:3000/admin/login
# With Supabase URL + service role: CRM uses Postgres; register at /admin/register (no local bootstrap).
# Without Supabase: first visit can bootstrap a local-password admin from ADMIN_BOOTSTRAP_* below.
ADMIN_SESSION_SECRET=change-this-to-a-long-random-string-min-16-chars
ADMIN_BOOTSTRAP_EMAIL=admin@bazooclaims.co.uk
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe123!
ADMIN_BOOTSTRAP_NAME=BAZOO Admin

# Supabase — full CRM when URL + service role are set (Postgres replaces data/admin-db.json).
# Use the project base URL only, e.g. https://abcdefghij.supabase.co (no /rest/v1, no trailing slash).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (never expose to the browser). With URL, this enables primary DB + staff auth_user_id preservation.
SUPABASE_SERVICE_ROLE_KEY=
#
# Apply SQL in supabase/migrations (001 → 004) before relying on Supabase mode.
#
# Admin login: Supabase Auth only when true or when Supabase is the primary store (no local password fallback).
ADMIN_SUPABASE_AUTH_ONLY=true
# Set to false to block /admin/register once any staff exist (default: registration stays open).
# ADMIN_ALLOW_PUBLIC_REGISTER=false
